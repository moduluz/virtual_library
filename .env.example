# ─── Database (Neon PostgreSQL) ───────────────────────────────────
# Get from https://neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require"

# ─── NextAuth.js ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-here"

# Your app's URL (no trailing slash)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── UploadThing (PDF Storage — FREE, no card required) ───────────
# Sign up FREE at https://uploadthing.com (uses GitHub login)
# Dashboard → Create App → Copy the token
UPLOADTHING_TOKEN="your-uploadthing-token"