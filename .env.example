# ─── Database (Neon PostgreSQL) ───────────────────────────────────
# Get from https://neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require"

# ─── NextAuth.js ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-here"

# Your app's URL (no trailing slash)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── UploadThing (PDF Storage — FREE, no card required) ───────────
# Sign up FREE at https://uploadthing.com (uses GitHub login)
# Dashboard → Create App → Copy the token
UPLOADTHING_TOKEN="your-uploadthing-token"

# ─── Rate Limiting (Upstash Redis — optional but recommended) ─────
# Sign up FREE at https://upstash.com (no card for free tier)
# Dashboard → Create Database → REST API → copy URL + Token
# Without these, rate limiting uses in-memory fallback (fine for local dev)
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Error Tracking (Sentry — optional) ───────────────────────────
# Sign up FREE at https://sentry.io → Create Project → Next.js
# Only active in production (NODE_ENV=production)
NEXT_PUBLIC_SENTRY_DSN="https://your-key@sentry.io/your-project-id"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="virtual-library"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"